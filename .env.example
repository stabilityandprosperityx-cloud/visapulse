# Site URL for canonical URLs, OG, sitemap, and robots (production)
NEXT_PUBLIC_SITE_URL=https://visapulse.relova.ai

# Supabase (required for dashboard data and submissions)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Salt for hashing visitor IPs (rate limiting). Use a long random string in production.
RATE_LIMIT_SALT=change-me-to-a-long-random-secret
